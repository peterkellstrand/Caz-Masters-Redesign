generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tournament {
  id                 String    @id @default(cuid())
  name               String
  year               Int       @unique
  date               DateTime
  location           String
  maxPlayers         Int       @default(72)
  registrationOpen   Boolean   @default(true)
  isLive             Boolean   @default(false)
  entryFee           Int       @default(15000) // cents
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  players            Player[]
  teams              Team[]
  holes              Hole[]
}

model Player {
  id              String    @id @default(cuid())
  fullName        String
  email           String
  phone           String
  shirtSize       String
  genderFlight    String
  teamPreference  String?
  returningPlayer Boolean   @default(false)
  dietaryNeeds    String?
  tournamentId    String
  tournament      Tournament @relation(fields: [tournamentId], references: [id])
  payment         Payment?
  teamId          String?
  team            Team?      @relation(fields: [teamId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([email, tournamentId])
}

model Payment {
  id              String   @id @default(cuid())
  playerId        String   @unique
  player          Player   @relation(fields: [playerId], references: [id])
  amount          Int      // cents
  status          String   @default("unpaid") // "paid_online", "paid_manual", "unpaid"
  stripeSessionId String?
  method          String?  // "stripe", "venmo", "manual", "day_of"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Team {
  id              String    @id @default(cuid())
  name            String
  tournamentId    String
  tournament      Tournament @relation(fields: [tournamentId], references: [id])
  players         Player[]
  scores          Score[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([name, tournamentId])
}

model Hole {
  id              String    @id @default(cuid())
  number          Int
  par             Int
  yardage         Int
  handicap        Int?
  tournamentId    String
  tournament      Tournament @relation(fields: [tournamentId], references: [id])
  scores          Score[]

  @@unique([number, tournamentId])
}

model Score {
  id              String    @id @default(cuid())
  strokes         Int
  teamId          String
  team            Team      @relation(fields: [teamId], references: [id])
  holeId          String
  hole            Hole      @relation(fields: [holeId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([teamId, holeId])
}
